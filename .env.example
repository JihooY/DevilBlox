DISCORD_TOKEN=
COMMAND_PREFIX=!
SYNC_COMMANDS=true
MESSAGE_CONTENT_INTENT=false
LOG_LEVEL=INFO
DISCORD_LOG_LEVEL=WARNING
LOG_FILE=logs/devilblox.log
LOG_MAX_BYTES=5242880
LOG_BACKUP_COUNT=5
COGS_PACKAGE=cogs
DISABLED_COGS=
VENDING_BANK_ACCOUNT=

# GIF delivery: auto uses CDN when GIF_CDN_BASE_URL is set, otherwise local files.
# CDN base should contain the GIF filenames directly (including verify_panel.gif).
GIF_DELIVERY_MODE=auto
GIF_CDN_BASE_URL=
GIF_LOCAL_VARIANT=original
# Keep this false to prevent the old once-per-minute full GIF re-upload pattern.
GIF_ROTATION_ENABLED=false
# After emergency recovery, local panels may upload only one new GIF per interval.
GIF_RECOVERY_UPLOAD_INTERVAL=5

# Discord operations panel and automatic traffic mitigation.
# Leave the channel empty and run /서버관리패널, or set one channel ID for auto-install.
OPERATIONS_MONITOR_ENABLED=true
OPERATIONS_CHANNEL_ID=
MONITOR_SAMPLE_INTERVAL=5
MONITOR_PANEL_INTERVAL=30
MONITOR_AUXILIARY_INTERVAL=30
MONITOR_CPU_CRITICAL_PERCENT=90
MONITOR_MEMORY_CRITICAL_PERCENT=90
MONITOR_DISK_CRITICAL_PERCENT=95
MONITOR_GPU_CRITICAL_PERCENT=95
MONITOR_NETWORK_DOWNLOAD_CRITICAL_MBPS=100
MONITOR_NETWORK_UPLOAD_CRITICAL_MBPS=100
# Optional exact psutil interface name (for example: Ethernet or eth0).
# Leave empty to monitor aggregate traffic across every interface.
MONITOR_NETWORK_INTERFACE=
MONITOR_LATENCY_CRITICAL_MS=1000
MONITOR_TRIGGER_SAMPLES=3
MONITOR_RECOVERY_SAMPLES=6
MONITOR_RECOVERY_RATIO=0.70
MONITOR_MITIGATION_COOLDOWN_SECONDS=300
MONITOR_ALERT_COOLDOWN_SECONDS=300
MONITOR_PROBE_ENABLED=true
MONITOR_PROBE_HOST=discord.com
MONITOR_PROBE_PORT=443
MONITOR_PROBE_TIMEOUT=3

# Use MONGO_URI when you already have one. If it is set, host/user fields below are ignored.
MONGO_URI=
MONGO_DB_NAME=devilblox

# Used when MONGO_URI is empty.
MONGO_HOST=127.0.0.1
MONGO_PORT=27017
MONGO_USER=
MONGO_PASSWORD=
MONGO_AUTH_DB=admin

# Optional SSH tunnel for remote MongoDB.
MONGO_USE_SSH=false
SSH_HOST=
SSH_PORT=22
SSH_USER=
SSH_KEY=
